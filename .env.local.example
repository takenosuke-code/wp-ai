# Copy this file to .env (or .env.local) and fill in your values.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: set BOTH to switch storage from local JSON files to Supabase.
# Server-only — never expose the service role key to the browser.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Optional: direct Postgres connection string — used ONLY for running schema
# migrations (supabase/*.sql), never by the app. Get it from the dashboard's
# "Connect" dialog. Rotate the DB password after sharing it.
# SUPABASE_URI=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Optional: enables semantic search (Voyage embeddings, voyage-3.5-lite, 1024-dim).
# Without it, grounding falls back to keyword search.
# VOYAGE_API_KEY=pa-...

# Optional: for the writer A/B test (scripts/writer-ab.mjs) — Kimi/DeepSeek via
# OpenRouter (US-hosted, avoids China data residency).
# OPENROUTER_API_KEY=sk-or-...
